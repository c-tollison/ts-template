{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "customConditions": ["development"],
        "types": ["node"],
        "strict": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true
    },
    "include": ["src"]
}
