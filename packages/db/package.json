{
    "name": "@ts-template/db",
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "generate": "drizzle-kit generate",
        "migrate": "drizzle-kit migrate",
        "seed": "node --env-file .env --import tsx src/scripts/seed.ts"
    },
    "devDependencies": {
        "@types/node": "^26.0.1",
        "@types/pg": "^8.20.0",
        "drizzle-kit": "^0.31.10",
        "tsx": "^4.22.4",
        "typescript": "~6.0.3"
    },
    "dependencies": {
        "@ts-template/types": "workspace:*",
        "drizzle-orm": "catalog:",
        "pg": "catalog:"
    }
}
